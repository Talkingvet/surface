{
  "name": "surface",
  "private": true,
  "version": "1.0.0",
  "description": "Surface — a calm, dark, minimal urgent-task tracker",
  "author": "Paul M",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "desktop": "npm run build && electron .",
    "dist": "npm run dist:win",
    "dist:win": "npm run build && electron-builder --win -c.electronDist=node_modules/electron/dist",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "build": {
    "appId": "com.surface.tasks",
    "productName": "Surface",
    "publish": null,
    "files": [
      "dist/**",
      "electron/**"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
